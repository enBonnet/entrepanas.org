{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "entrepanas",
	"compatibility_date": "2025-09-02",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"main": "src/server.ts",
	"observability": {
		"enabled": true
	},
	// Nightly Cron Trigger recomputes every recipient's reputation as a drift
	// safety-net (03:00 UTC). The custom entrypoint re-exports the TanStack
	// fetch handler and adds the scheduled() handler — the virtual server-entry
	// module can't export scheduled.
	"triggers": {
		"crons": ["0 3 * * *"]
	},
	// Cloudflare D1 (SQLite-dialect) — the all-Cloudflare DB. Create with:
	//   npx wrangler d1 create entrepanas   (then paste the returned database_id below for remote deploys)
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "entrepanas",
			"database_id": "ae1d87a5-1376-4a10-a492-2d625f5f2521",
			"migrations_dir": "./drizzle"
		}
	],
	// R2 bucket for evidence images. Create with:
	//   npx wrangler r2 bucket create entrepanas-evidence
	"r2_buckets": [
		{
			"binding": "EVIDENCE_BUCKET",
			"bucket_name": "entrepanas-evidence"
		}
	],
	// Non-secret config. Secrets (R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY,
	// BETTER_AUTH_SECRET) go in .dev.vars locally and `wrangler secret put` in prod.
	"vars": {
		"R2_ACCOUNT_ID": "3a1bc7f182750ece2bf1becab111b0b6",
		"R2_BUCKET_NAME": "entrepanas-evidence",
		"UPLOAD_MAX_BYTES": "10485760",
		"REPUTATION_PUBLIC_TIER": "0"
	}
}